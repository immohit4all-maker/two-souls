# PostgreSQL connection (Amazon RDS or Aurora PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/twosouls?schema=public"

# AWS S3 bucket used for product images. Keep these server-side only.
AWS_REGION="ap-south-1"
AWS_S3_BUCKET="two-souls-product-assets"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# Cognito values for admin sign-in (add when authentication is wired in)
NEXT_PUBLIC_COGNITO_USER_POOL_ID=""
NEXT_PUBLIC_COGNITO_CLIENT_ID=""
